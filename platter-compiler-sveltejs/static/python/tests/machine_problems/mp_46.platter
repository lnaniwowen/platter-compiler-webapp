piece of maxAttempts = 5;

start(){
    piece of secret = 0;
    piece of attempts = 0;
    piece of guess = 0;
    piece of attemptsLeft = 0;
    chars of raw = "";
    flag of won = down;

    repeat(up){
        secret = topiece(rand() * 100.0) + 1;
        attempts = 0;
        won = down;

        bill("\n==============================\n");
        bill("Guessing Game\n");
        bill("==============================\n");
        bill("I picked a secret number from 1 to 100.\n");
        bill("You have " + tochars(maxAttempts) + " attempts.\n");
        bill("Type exit to quit the game.\n");

        repeat(attempts < maxAttempts){
            bill("Enter your guess: ");
            raw = take();

            check(raw == "exit"){
                bill("\nThanks for playing.\n");
                serve 0;
            } instead {
                guess = topiece(raw);

                check(guess == secret){
                    won = up;
                    bill("Correct! You guessed the secret number.\n");
                    stop;
                } alt(guess < secret){

                    attempts = attempts + 1;
                    attemptsLeft = maxAttempts - attempts;
                    bill("Too low. Attempts left: " + tochars(attemptsLeft) + "\n");
                } instead {
                    attempts = attempts + 1;
                    attemptsLeft = maxAttempts - attempts;
                    bill("Too high. Attempts left: " + tochars(attemptsLeft) + "\n");
                }
            }
            check(guess == secret){
                stop;
            }
        }
        check(not won){
            bill("Out of attempts. Secret number was " + tochars(secret) + ".\n");
        }
        bill("Starting a new round...\n");
    }

    serve 0;
}
